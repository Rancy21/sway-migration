#!/bin/bash
# launch-tui: Launch TUI application in terminal
# Usage: launch-tui <command>

COMMAND="$1"

if [ -z "$COMMAND" ]; then
    echo "Usage: launch-tui <command>"
    exit 1
fi

# Launch in default terminal
if command -v xdg-terminal-exec &>/dev/null; then
    xdg-terminal-exec -- "$COMMAND"
elif command -v alacritty &>/dev/null; then
    alacritty -e "$COMMAND"
elif command -v foot &>/dev/null; then
    foot "$COMMAND"
elif command -v kitty &>/dev/null; then
    kitty "$COMMAND"
else
    echo "No terminal found"
    exit 1
fi
