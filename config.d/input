# Input Configuration
# Keyboard, mouse, and touchpad settings
# Migrated from Omarchy/Hyprland

# ================================
# KEYBOARD SETTINGS
# ================================

input type:keyboard {
    # Keyboard layout
    xkb_layout us
    # xkb_variant ,nodeadkeys
    # xkb_model pc104

    # NumLock on by default
    xkb_numlock enabled

    # Repeat rate (for holding keys)
    repeat_delay 300
    repeat_rate 50

    # Caps Lock behavior
    # xkb_options caps:escape        # Map Caps Lock to Escape
    # xkb_options caps:ctrl_modifier # Map Caps Lock to Ctrl
}

# Keyboard-specific settings (example)
# input 1:1:AT_Translated_Set_2_keyboard {
#     xkb_layout us,de
#     xkb_options grp:alt_shift_toggle
# }

# ================================
# TOUCHPAD SETTINGS
# ================================

input type:touchpad {
    # Tap to click
    tap enabled

    # Natural scrolling (like macOS)
    natural_scroll enabled

    # Disable while typing
    dwt enabled

    # Click method
    click_method clickfinger

    # Middle click emulation
    middle_emulation enabled

    # Scroll factor (speed)
    scroll_factor 1.0

    # Tap-and-drag
    tap_drag enabled

    # Disable tap-to-select
    # tap_button_map lrm
}

# Touchpad-specific settings (example - use swaymsg -t get_inputs to find device name)
# input 2:14:ETPS/2_Elantech_Touchpad {
#     dwt enabled
#     tap enabled
#     natural_scroll enabled
#     scroll_factor 0.5
# }

# ================================
# MOUSE SETTINGS
# ================================

input type:pointer {
    # Acceleration
    accel_profile adaptive

    # Pointer speed (-1.0 to 1.0)
    pointer_accel 0.0

    # Natural scrolling for mouse (usually off)
    natural_scroll disabled

    # Scroll factor
    scroll_factor 1.0

    # Middle button emulation (2-button mouse)
    middle_emulation disabled

    # Left-handed mode
    left_handed disabled
}

# Mouse-specific settings (example)
# input 1133:4122:Logitech_G305 {
#     pointer_accel -0.3
#     accel_profile flat
# }

