# ================================
# INPUT METHOD EDITOR (IME)
# ================================

# If using CJK input or other IME
# exec fcitx5 -d --replace
# exec ibus-daemon -drx

# ================================
# GESTURES (Limited support in Sway)
# ================================

# Sway has limited gesture support compared to Hyprland
# Hyprland's gesture = 3, horizontal, workspace, e 5
# would need to be handled by a gesture daemon like libinput-gestures

# Example with libinput-gestures:
# exec_always libinput-gestures-setup start

# Or use fusuma:
# exec_always fusuma -d

# ================================
# SEAT CONFIGURATION
# ================================

# Cursor theme
seat seat0 xcursor_theme Adwaita 24

# Cursor hiding after timeout (milliseconds)
# seat seat0 hide_cursor 5000

# ================================
# BINDINGS MODES FOR INPUT
# ================================

# Keyboard layout switcher mode
set $mode_layout Keyboard layout
mode "$mode_layout" {
    bindsym 1 input type:keyboard xkb_layout us; mode "default"
    bindsym 2 input type:keyboard xkb_layout de; mode "default"
    bindsym 3 input type:keyboard xkb_layout fr; mode "default"
    bindsym Escape mode "default"
}
# bindsym $mod+Shift+k mode "$mode_layout"

# Touchpad toggle mode
set $mode_touchpad Touchpad
mode "$mode_touchpad" {
    bindsym t input type:touchpad events toggle enabled disabled; mode "default"
    bindsym Escape mode "default"
}
# bindsym $mod+Ctrl+t mode "$mode_touchpad"
