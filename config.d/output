# monitor= eDP-1, 1366x768@60, 0x0, 0.9

# Uncomment and adjust when ready:
# output eDP-1 mode 1366x768@60Hz scale 0.9 pos 0 0

# Second monitor example from Hyprland:
# monitor=,1600x900@60,auto,1

# Generic fallback (uses auto position):
# output * mode preferred scale 1.0
