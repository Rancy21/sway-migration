# Appearance Configuration
# Catppuccin Mocha theme - migrated from Omarchy

# Set gaps (like Hyprland)
gaps inner 5
gaps outer 10

# Borders
default_border pixel 2
default_floating_border pixel 2

# Hide edge borders when there's only one window
hide_edge_borders smart

# Window colors
# Catppuccin Mocha color palette
set $base #1e1e2e
set $mantle #181825
set $crust #11111b

set $text #cdd6f4
set $subtext0 #a6adc8
set $subtext1 #bac2de

set $surface0 #313244
set $surface1 #45475a
set $surface2 #585b70

set $overlay0 #6c7086
set $overlay1 #7f849c
set $overlay2 #9399b2

set $blue #89b4fa
set $lavender #b4befe
set $sapphire #74c7ec
set $sky #89dceb
set $teal #94e2d5
set $green #a6e3a1
set $yellow #f9e2af
set $peach #fab387
set $maroon #eba0ac
set $red #f38ba8
set $mauve #cba6f7
set $pink #f5c2e7
set $flamingo #f2cdcd
set $rosewater #f5e0dc

#                       border      background   text    indicator   child_border
client.focused          $blue       $base        $text   $lavender   $blue
client.focused_inactive $surface1   $base        $text   $surface1   $surface1
client.unfocused        $surface0   $base        $text   $surface0   $surface0
client.urgent           $red        $base        $text   $red        $red
client.placeholder      $surface0   $base        $text   $surface0   $surface0
client.background       $base

# Background color (solid)
output * bg $base solid_color

# Font
font pango:JetBrainsMono Nerd Font 10

# Title bar configuration
titlebar_padding 5 2
title_align center

# Corner radius (Sway doesn't support per-window rounding like Hyprland,
# but you can use a compositor like picom if needed)
# corner_radius 8 (requires picom or similar)

# Smart gaps (no gaps when only one window on workspace)
# smart_gaps on
# smart_borders on

# Focus wrapping
focus_wrapping no

# Mouse focus
focus_follows_mouse yes
mouse_warping output

# Floating window settings
floating_maximum_size 1920 x 1080
floating_minimum_size 75 x 50

# Popup handling
popup_during_fullscreen leave_fullscreen

# Urgency handling
for_window [urgent=latest] focus

# No gaps mode (toggle with a keybinding if desired)
set $mode_gaps gaps
mode "$mode_gaps" {
    bindsym plus gaps inner current plus 5
    bindsym minus gaps inner current minus 5
    bindsym 0 gaps inner current set 0
    bindsym Shift+plus gaps outer current plus 5
    bindsym Shift+minus gaps outer current minus 5
    bindsym Shift+0 gaps outer current set 0

    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+Shift+g mode "$mode_gaps"

# ================================
# ANIMATIONS (Minimal - Sway doesn't support Hyprland's advanced animations)
# ================================

# Sway has limited animation support compared to Hyprland
# Available options are fade and slide effects

# Enable fading
# enable_fade true

# Enable sliding
# enable_slide true

# You can use picom for more advanced effects:
# exec_always picom --config ~/.config/picom/picom.conf

# ================================
# LAYER RULES (Sway alternative to Hyprland layerrule)
# ================================

# Sway doesn't have Hyprland's layerrule system, but you can:
# 1. Use layer-shell protocol aware apps
# 2. Use window rules for specific apps

# Example: make specific windows floating
for_window [app_id="pavucontrol"] floating enable
for_window [app_id="nm-connection-editor"] floating enable
for_window [app_id="blueman-manager"] floating enable
for_window [title="File Operation Progress"] floating enable
for_window [title="Confirm to replace files"] floating enable
for_window [window_role="pop-up"] floating enable
for_window [window_role="dialog"] floating enable

